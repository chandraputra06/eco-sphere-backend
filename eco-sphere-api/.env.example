# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed origins (your Vercel URL + localhost)
CORS_ORIGINS=http://localhost:5173,https://eco-sphere.vercel.app

# ── Auth ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ── AI (server-side only — never expose to the client) ───
# Leave empty to run the AI endpoint in MOCK mode (great for local dev / demos).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Database (production) ────────────────────────────────
# The dev server uses an in-memory store and ignores this.
# Set this on Render and switch the data layer to Prisma when ready.
DATABASE_URL=
