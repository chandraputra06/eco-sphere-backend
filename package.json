{
  "name": "eco-sphere-api",
  "version": "1.0.0",
  "description": "Eco-Sphere backend — Express + Prisma (MySQL)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "postinstall": "prisma generate",
    "seed": "node prisma/seed.js",
    "db:migrate": "prisma migrate deploy"
  },
  "prisma": { "seed": "node prisma/seed.js" },
  "engines": { "node": ">=20" },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "prisma": "^6.2.1",
    "zod": "^3.24.1"
  }
}
